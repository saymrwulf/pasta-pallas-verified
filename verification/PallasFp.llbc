Scalar(false));"},{"DocComment":" assert_eq!(Scalar(false) & Scalar(true), Scalar(false));"},{"DocComment":" assert_eq!(Scalar(false) & Scalar(false), Scalar(false));"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" An implementation of `BitAnd` for a wrapper around `Vec<bool>`."},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ops::BitAnd;"},{"DocComment":""},{"DocComment":" #[derive(Debug, PartialEq)]"},{"DocComment":" struct BooleanVector(Vec<bool>);"},{"DocComment":""},{"DocComment":" impl BitAnd for BooleanVector {"},{"DocComment":"     type Output = Self;"},{"DocComment":""},{"DocComment":"     fn bitand(self, Self(rhs): Self) -> Self::Output {"},{"DocComment":"         let Self(lhs) = self;"},{"DocComment":"         assert_eq!(lhs.len(), rhs.len());"},{"DocComment":"         Self("},{"DocComment":"             lhs.iter()"},{"DocComment":"                 .zip(rhs.iter())"},{"DocComment":"                 .map(|(x, y)| *x & *y)"},{"DocComment":"                 .collect()"},{"DocComment":"         )"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" let bv1 = BooleanVector(vec![true, true, false, false]);"},{"DocComment":" let bv2 = BooleanVector(vec![true, false, true, false]);"},{"DocComment":" let expected = BooleanVector(vec![true, false, false, false]);"},{"DocComment":" assert_eq!(bv1 & bv2, expected);"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"bitand"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"},{"index":1,"name":"Rhs"},{"index":2,"name":"Self_Output"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[null],"methods":[{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"bitand","attr_info":{"attribut