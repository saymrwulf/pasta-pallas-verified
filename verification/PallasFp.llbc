 is a non-square."},{"DocComment":""},{"DocComment":" # Warnings"},{"DocComment":""},{"DocComment":" - The choice of root from `sqrt` is unspecified."},{"DocComment":" - The value of $G_S$ is unspecified, and cannot be assumed to have any specific"},{"DocComment":"   value in a generic context."}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":8361},{"Deduplicated":8369}],"output":{"Deduplicated":8391}},"item":{"id":90,"generics":{"regions":[{"Var":{"Bound":[0,0]}},{"Var":{"Bound":[0,1]}}],"types":[{"Deduplicated":8294}],"const_generics":[],"trait_refs":[{"Deduplicated":8389}]}}},"kind":{"TraitMethod":[24,7]}},null,{"params":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"sqrt","attr_info":{"attributes":[{"DocComment":" Returns the square root of the field element, if it is"},{"DocComment":" quadratic residue."},{"DocComment":""},{"DocComment":" The provided method is implemented in terms of [`Self::sqrt_ratio`]."}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":8361}],"output":{"Deduplicated":8390}},"item":{"id":92,"generics":{"regions":[{"Var":{"Bound":[0,0]}}],"types":[{"Deduplicated":8294}],"const_generics":[],"trait_refs":[{"Deduplicated":8389}]}}},"kind":{"TraitMethod":[24,9]}},null,{"params":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[{"index":0,"name":"S"}],"const_generics":[],"trait_clauses":[{"clause_id":0,"span":{"data":{"file_id":21,"beg":{"line":178,"col":22},"end":{"line":178,"col":34}},"generated_from_span":null},"origin":"WhereClauseOnFn","trait_":{"regions":[],"skip_binder":{"id":28,"generics":{"regions":[],"types":[{"Deduplicated":1092},{"Deduplicated":2074}],"const_generics":[],"trait_refs":[]}}}}],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"pow_vartime","attr_info":{"attributes":[{"DocComment":" Exponentiates `self` by `exp`, where `exp` is a little-endian order integer"},{"DocComment":" exponent."},{"DocComment":""},{"DocComment":" # Guarantees"},{"DocComment":""},{"DocComment":" **This operation is variable time with respect to `self`, for all exponent.** If"},{"DocComment":" the exponent is fixed, this operation is effectively constant time. However, for"},{"DocComment":" stronger constant-time guarantees, [`Field::pow`] should be used."}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":8361},{"Deduplicated":1091}],"output":{"Deduplicated":8294}},"item":{"id":94,"generics":{"regions":[{"Var":{"Bound":[0,0]}}],"types":[{"Deduplicated":8294},{"Deduplicated":1091}],"const_generics":[],"trait_refs":[{"Deduplicated":8389},{"HashConsedValue":[2077,{"kind":{"Clause":{"Bound":[0,0]}},"trait_decl_ref":{"regions":[],"skip_binder":{"id":28,"generics":{"regions":[],"types":[{"Deduplicated":1092},{"Deduplicated":2074}],"const_generics":[],"trait_refs":[]}}}}]}]}}},"kind":{"TraitMethod":[24,11]}}],"vtable":null},{"def_id":25,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["marker",0]},{"Ident":["Send",0]}],"span":{"data":{"file_id":6,"beg":{"line":92,"col":0},"end":{"line":92,"col":26}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Types that can be transferred across thread boundaries."},{"DocComment":""},{"DocComment":" This trait is automatically implemented when the compiler determines it's"},{"DocComment":" appropriate."},{"DocComment":""},{"DocComment":" An example of a non-`Send` type is the reference-counting pointer"},{"DocComment":" [`rc::Rc`][`Rc`]. If two threads attempt to clone [`Rc`]s that point to the same"},{"DocComment":" reference-counted value, they might try to update the reference count at the"},{"DocComment":" same time, which is [undefined behavior][ub] because [`Rc`] doesn't use atomic"},{"DocComment":" operations. Its cousin [`sync::Arc`][arc] does use atomic operations (incurring"},{"DocComment":" some overhead) and thus is `Send`."},{"DocComment":""},{"DocComment":" See [the Nomicon](../../nomicon/send-and-sync.html) and the [`Sync`] trait for more details."},{"DocComment":""},{"DocComment":" [`Rc`]: ../../std/rc/struct.Rc.html"},{"DocComment":" [arc]: ../../std/sync/struct.Arc.html"},{"DocComment":" [ub]: ../../reference/behavior-considered-undefined.html"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"Send"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[],"methods":[],"vtable":{"id":{"Adt":49},"generics":{"regions":[],"types":[],"const_generics":[],"trait_refs":[]}}},{"def_id":26,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["marker",0]},{"Ident":["Sync",0]}],"span":{"data":{"file_id":6,"beg":{"line":657,"col":0},"end":{"line":657,"col":26}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Types for which it is safe to share references between threads."},{"DocComment":""},{"DocComment":" This trait is automatically implemented when the compiler determines"},{"DocComment":" it's appropriate."},{"DocComment":""},{"DocComment":" The precise definition is: a type `T` is [`Sync`] if and only if `&T` is"},{"DocComment":" [`Send`]. In other words, if there is no possibility of"},{"DocComment":" [undefined behavior][ub] (including data races) when passing"},{"DocComment":" `&T` references between threads."},{"DocComment":""},{"DocComment":" As one would expect, primitive types like [`u8`] and [`f64`]"},{"DocComment":" are all [`Sync`], and so are simple aggregate types containing them,"},{"DocComment":" like tuples, structs and enums. More examples of basic [`Sync`]"},{"DocComment":" types include \"immutable\" types like `&T`, and those with simple"},{"DocComment":" inherited mutability, such as [`Box<T>`][box], [`Vec<T>`][vec] and"},{"DocComment":" most other collection types. (Generic parameters need to be [`Sync`]"},{"DocComment":" for their container to be [`Sync`].)"},{"DocComment":""},{"DocComment":" A somewhat surprising consequence of the definition is that `&mut T`"},{"DocComment":" is `Sync` (if `T` is `Sync`) even though it seems like that might"},{"DocComment":" provide unsynchronized mutation. The trick is that a mutable"},{"DocComment":" reference behind a shared reference (that is, `& &mut T`)"},{"DocComment":" becomes read-only, as if it were a `& &T`. Hence there is no risk"},{"DocComment":" of a data race."},{"DocComment":""},{"DocComment":" A shorter overview of how [`Sync`] and [`Send`] relate to referencing:"},{"DocComment":" * `&T` is [`Send`] if and only if `T` is [`Sync`]"},{"DocComment":" * `&mut T` is [`Send`] if and only if `T` is [`Send`]"},{"DocComment":" * `&T` and `&mut T` are [`Sync`] if and only if `T` is [`Sync`]"},{"DocComment":""},{"DocComment":" Types that are not `Sync` are those that have \"interior"},{"DocComment":" mutability\" in a non-thread-safe form, such as [`Cell`][cell]"},{"DocComment":" and [`RefCell`][refcell]. These types allow for mutation of"},{"DocComment":" their contents even through an immutable, shared reference. For"},{"DocComment":" example the `set` method on [`Cell<T>`][cell] takes `&self`, so it requires"},{"DocComment":" only a shared reference [`&Cell<T>`][cell]. The method performs no"},{"DocComment":" synchronization, thus [`Cell`][cell] cannot be `Sync`."},{"DocComment":""},{"DocComment":" Another example of a non-`Sync` type is the reference-counting"},{"DocComment":" pointer [`Rc`][rc]. Given any reference [`&Rc<T>`][rc], you can clone"},{"DocComment":" a new [`Rc<T>`][rc], modifying the reference counts in a non-atomic way."},{"DocComment":""},{"DocComment":" For cases when one does need thread-safe interior mutability,"},{"DocComment":" Rust provides [atomic data types], as well as explicit locking via"},{"DocComment":" [`sync::Mutex`][mutex] and [`sync::RwLock`][rwlock]. These types"},{"DocComment":" ensure that any mutation cannot cause data races, hence the types"},{"DocComment":" are `Sync`. Likewise, [`sync::Arc`][arc] provides a thread-safe"},{"DocComment":" analogue of [`Rc`][rc]."},{"DocComment":""},{"DocComment":" Any types with interior mutability must also use the"},{"DocComment":" [`cell::UnsafeCell`][unsafecell] wrapper around the value(s) which"},{"DocComment":" can be mutated through a shared reference. Failing to doing this is"},{"DocComment":" [undefined behavior][ub]. For example, [`transmute`][transmute]-ing"},{"DocComment":" from `&T` to `&mut T` is invalid."},{"DocComment":""},{"DocComment":" See [the Nomicon][nomicon-send-and-sync] for more details about `Sync`."},{"DocComment":""},{"DocComment":" [box]: ../../std/boxed/struct.Box.html"},{"DocComment":" [vec]: ../../std/vec/struct.Vec.html"},{"DocComment":" [cell]: crate::cell::Cell"},{"DocComment":" [refcell]: crate::cell::RefCell"},{"DocComment":" [rc]: ../../std/rc/struct.Rc.html"},{"DocComment":" [arc]: ../../std/sync/struct.Arc.html"},{"DocComment":" [atomic data types]: crate::sync::atomic"},{"DocComment":" [mutex]: ../../std/sync/struct.Mutex.html"},{"DocComment":" [rwlock]: ../../std/sync/struct.RwLock.html"},{"DocComment":" [unsafecell]: crate::cell::UnsafeCell"},{"DocComment":" [ub]: ../../reference/behavior-considered-undefined.html"},{"DocComment":" [transmute]: crate::mem::transmute"},{"DocComment":" [nomicon-send-and-sync]: ../../nomicon/send-and-sync.html"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"sync"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[],"methods":[],"vtable":{"id":{"Adt":50},"generics":{"regions":[],"types":[],"const_generics":[],"trait_refs":[]}}},{"def_id":27,"item_meta":{"name":[{"Ident":["rand_core",0]},{"Ident":["RngCore",0]}],"span":{"data":{"file_id":22,"beg":{"line":142,"col":0},"end":{"line":142,"col":17}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" The core of a random number generator."},{"DocComment":""},{"DocComment":" This trait encapsulates the low-level functionality common to all"},{"DocComment":" generators, and is the \"back end\", to be implemented by generators."},{"DocComment":" End users should normally use the `Rng` trait from the [`rand`] crate,"},{"DocComment":" which is automatically implemented for every type implementing `RngCore`."},{"DocComment":""},{"DocComment":" Three different methods for generating random data are provided since the"},{"DocComment":" optimal implementation of each is dependent on the type of generator. There"},{"DocComment":" is no required relationship between the output of each; e.g. many"},{"DocComment":" implementations of [`fill_bytes`] consume a whole number of `u32` or `u64`"},{"DocComment":" values and drop any remaining unused bytes. The same can happen with the"},{"DocComment":" [`next_u32`] and [`next_u64`] methods, implementations may discard some"},{"DocComment":" random bits for efficiency."},{"DocComment":""},{"DocComment":" The [`try_fill_bytes`] method is a variant of [`fill_bytes`] allowing error"},{"DocComment":" handling; it is not deemed sufficiently useful to add equivalents for"},{"DocComment":" [`next_u32`] or [`next_u64`] since the latter methods are almost always used"},{"DocComment":" with algorithmic generators (PRNGs), which are normally infallible."},{"DocComment":""},{"DocComment":" Implementers should produce bits uniformly. Pathological RNGs (e.g. always"},{"DocComment":" returning the same value, or never setting certain bits) can break rejection"},{"DocComment":" sampling used by random distributions, and also break other RNGs when"},{"DocComment":" seeding them via [`SeedableRng::from_rng`]."},{"DocComment":""},{"DocComment":" Algorithmic generators implementing [`SeedableRng`] should normally have"},{"DocComment":" *portable, reproducible* output, i.e. fix Endianness when converting values"},{"DocComment":" to avoid platform differences, and avoid making any changes which affect"},{"DocComment":" output (except by communicating that the release has breaking changes)."},{"DocComment":""},{"DocComment":" Typically an RNG will implement only one of the methods available"},{"DocComment":" in this trait directly, then use the helper functions from the"},{"DocComment":" [`impls`] module to implement the other methods."},{"DocComment":""},{"DocComment":" It is recommended that implementations also implement:"},{"DocComment":""},{"DocComment":" - `Debug` with a custom implementation which *does not* print any internal"},{"DocComment":"   state (at least, [`CryptoRng`]s should not risk leaking state through"},{"DocComment":"   `Debug`)."},{"DocComment":" - `Serialize` and `Deserialize` (from Serde), preferably making Serde"},{"DocComment":"   support optional at the crate level in PRNG libs."},{"DocComment":" - `Clone`, if possible."},{"DocComment":" - *never* implement `Copy` (accidental copies may cause repeated values)."},{"DocComment":" - *do not* implement `Default` for pseudorandom generators, but instead"},{"DocComment":"   implement [`SeedableRng`], to guide users towards proper seeding."},{"DocComment":"   External / hardware RNGs can choose to implement `Default`."},{"DocComment":" - `Eq` and `PartialEq` could be implemented, but are probably not useful."},{"DocComment":""},{"DocComment":" # Example"},{"DocComment":""},{"DocComment":" A simple example, obviously not generating very *random* output:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" #![allow(dead_code)]"},{"DocComment":" use rand_core::{RngCore, Error, impls};"},{"DocComment":""},{"DocComment":" struct CountingRng(u64);"},{"DocComment":""},{"DocComment":" impl RngCore for CountingRng {"},{"DocComment":"     fn next_u32(&mut self) -> u32 {"},{"DocComment":"         self.next_u64() as u32"},{"DocComment":"     }"},{"DocComment":""},{"DocComment":"     fn next_u64(&mut self) -> u64 {"},{"DocComment":"         self.0 += 1;"},{"DocComment":"         self.0"},{"DocComment":"     }"},{"DocComment":""},{"DocComment":"     fn fill_bytes(&mut self, dest: &mut [u8]) {"},{"DocComment":"         impls::fill_bytes_via_next(self, dest)"},{"DocComment":"     }"},{"DocComment":""},{"DocComment":"     fn try_fill_bytes(&mut self, dest: &mut [u8]) -> Result<(), Error> {"},{"DocComment":"         Ok(self.fill_bytes(dest))"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [`rand`]: https://docs.rs/rand"},{"DocComment":" [`try_fill_bytes`]: RngCore::try_fill_bytes"},{"DocComment":" [`fill_bytes`]: RngCore::fill_bytes"},{"DocComment":" [`next_u32`]: RngCore::next_u32"},{"DocComment":" [`next_u64`]: RngCore::next_u64"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":null},"generics":{"regions":[],"types":[{"index":0,"name":"Self"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[],"methods":[{"params":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"next_u32","attr_info":{"attributes":[{"DocComment":" Return the next random `u32`."},{"DocComment":""},{"DocComment":" RNGs must implement at least one method from this trait directly. In"},{"DocComment":" the case this method is not implemented directly, it can be implemented"},{"DocComment":" using `self.next_u64() as u32` or via [`impls::next_u32_via_fill`]."}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":8363}],"output":{"Deduplicated":1834}},"item":{"id":219,"generics":{"regions":[{"Var":{"Bound":[0,0]}}],"types":[{"Deduplicated":8294}],"const_generics":[],"trait_refs":[{"HashConsedValue":[8392,{"kind":"SelfId","trait_decl_ref":{"regions":[],"skip_binder":{"id":27,"generics":{"regions":[],"types":[{"Deduplicated":8294}],"const_generics":[],"trait_refs":[]}}}}]}]}}},"kind":{"TraitMethod":[27,0]}},{"params":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"next_u64","attr_info":{"attributes":[{"DocComment":" Return the next random `u64`."},{"DocComment":""},{"DocComment":" RNGs must implement at least one method from this trait directly. In"},{"DocComment":" the case this method is not implemented directly, it can be implemented"},{"DocComment":" via [`impls::next_u64_via_u32`] or via [`impls::next_u64_via_fill`]."}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":8363}],"output":{"Deduplicated":1072}},"item":{"id":220,"generics":{"regions":[{"Var":{"Bound":[0,0]}}],"types":[{"Deduplicated":8294}],"const_generics":[],"trait_refs":[{"Deduplicated":8392}]}}},"kind":{"TraitMethod":[27,1]}},{"params":{"regions":[{"index":0,"name":null,"mutability":"Unknown"},{"index":1,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"fill_bytes","attr_info":{"attributes":[{"DocComment":" Fill `dest` with random data."},{"DocComment":""},{"DocComment":" RNGs must implement at least one method from this trait directly. In"},{"DocComment":" the case this method is not implemented directly, it can be implemented"},{"DocComment":" via [`impls::fill_bytes_via_next`] or"},{"DocComment":" via [`RngCore::try_fill_bytes`]; if this generator can"},{"DocComment":" fail the implementation must choose how best to handle errors here"},{"DocComment":" (e.g. panic with a descriptive message or log a warning and retry a few"},{"DocComment":" times)."},{"DocComment":""},{"DocComment":" This method should guarantee that `dest` is entirely filled"},{"DocComment":" with new data, and may panic if this is impossible"},{"DocComment":" (e.g. reading past the end of a file that is being used as the"},{"DocComment":" source of randomness)."}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":8363},{"HashConsedValue":[4787,{"Ref":[{"Var":{"Bound":[0,1]}},{"Deduplicated":2162},"Mut"]}]}],"output":{"Deduplicated":1108}},"item":{"id":221,"generics":{"regions":[{"Var":{"Bound":[0,0]}},{"Var":{"Bound":[0,1]}}],"types":[{"Deduplicated":8294}],"const_generics":[],"trait_refs":[{"Deduplicated":8392}]}}},"kind":{"TraitMethod":[27,2]}},{"params":{"regions":[{"index":0,"name":null,"mutability":"Unknown"},{"index":1,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"try_fill_bytes","attr_info":{"attributes":[{"DocComment":" Fill `dest` entirely with random data."},{"DocComment":""},{"DocComment":" This is the only method which allows an RNG to report errors while"},{"DocComment":" generating random data thus making this the primary method implemented"},{"DocComment":" by external (true) RNGs (e.g. `OsRng`) which can fail. It may be used"},{"DocComment":" directly to generate keys and to seed (infallible) PRNGs."},{"DocComment":""},{"DocComment":" Other than error handling, this method is identical to [`RngCore::fill_bytes`];"},{"DocComment":" thus this may be implemented using `Ok(self.fill_bytes(dest))` or"},{"DocComment":" `fill_bytes` may be implemented with"},{"DocComment":" `self.try_fill_bytes(dest).unwrap()` or more specific error handling."}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":8363},{"Deduplicated":4787}],"output":{"Deduplicated":4813}},"item":{"id":222,"generics":{"regions":[{"Var":{"Bound":[0,0]}},{"Var":{"Bound":[0,1]}}],"types":[{"Deduplicated":8294}],"const_generics":[],"trait_refs":[{"Deduplicated":8392}]}}},"kind":{"TraitMethod":[27,3]}}],"vtable":{"id":{"Adt":51},"generics":{"regions":[],"types":[],"const_generics":[],"trait_refs":[]}}},{"def_id":28,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["convert",0]},{"Ident":["AsRef",0]}],"span":{"data":{"file_id":9,"beg":{"line":219,"col":0},"end":{"line":219,"col":52}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Used to do a cheap reference-to-reference conversion."},{"DocComment":""},{"DocComment":" This trait is similar to [`AsMut`] which is used for converting between mutable references."},{"DocComment":" If you need to do a costly conversion it is better to implement [`From`] with type"},{"DocComment":" `&T` or write a custom function."},{"DocComment":""},{"DocComment":" # Relation to `Borrow`"},{"DocComment":""},{"DocComment":" `AsRef` has the same signature as [`Borrow`], but [`Borrow`] is different in a few aspects:"},{"DocComment":""},{"DocComment":" - Unlike `AsRef`, [`Borrow`] has a blanket impl for any `T`, and can be used to accept either"},{"DocComment":"   a reference or a value. (See also note on `AsRef`'s reflexibility below.)"},{"DocComment":" - [`Borrow`] also requires that [`Hash`], [`Eq`] and [`Ord`] for a borrowed value are"},{"DocComment":"   equivalent to those of the owned value. For this reason, if you want to"},{"DocComment":"   borrow only a single field of a struct you can implement `AsRef`, but not [`Borrow`]."},{"DocComment":""},{"DocComment":" **Note: This trait must not fail**. If the conversion can fail, use a"},{"DocComment":" dedicated method which returns an [`Option<T>`] or a [`Result<T, E>`]."},{"DocComment":""},{"DocComment":" # Generic Implementations"},{"DocComment":""},{"DocComment":" `AsRef` auto-dereferences if the inner type is a reference or a mutable reference"},{"DocComment":" (e.g.: `foo.as_ref()` will work the same if `foo` has type `&mut Foo` or `&&mut Foo`)."},{"DocComment":""},{"DocComment":" Note that due to historic reasons, the above currently does not hold generally for all"},{"DocComment":" [dereferenceable types], e.g. `foo.as_ref()` will *not* work the same as"},{"DocComment":" `Box::new(foo).as_ref()`. Instead, many smart pointers provide an `as_ref` implementation which"},{"DocComment":" simply returns a reference to the [pointed-to value] (but do not perform a cheap"},{"DocComment":" reference-to-reference conversion for that value). However, [`AsRef::as_ref`] should not be"},{"DocComment":" used for the sole purpose of dereferencing; instead ['`Deref` coercion'] can be used:"},{"DocComment":""},{"DocComment":" [dereferenceable types]: core::ops::Deref"},{"DocComment":" [pointed-to value]: core::ops::Deref::Target"},{"DocComment":" ['`Deref` coercion']: core::ops::Deref#deref-coercion"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let x = Box::new(5i32);"},{"DocComment":" // Avoid this:"},{"DocComment":" // let y: &i32 = x.as_ref();"},{"DocComment":" // Better just write:"},{"DocComment":" let y: &i32 = &x;"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Types which implement [`Deref`] should consider implementing `AsRef<T>` as follows:"},{"DocComment":""},{"DocComment":" [`Deref`]: core::ops::Deref"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" # use core::ops::Deref;"},{"DocComment":" # struct SomeType;"},{"DocComment":" # impl Deref for SomeType {"},{"DocComment":" #     type Target = [u8];"},{"DocComment":" #     fn deref(&self) -> &[u8] {"},{"DocComment":" #         &[]"},{"DocComment":" #     }"},{"DocComment":" # }"},{"DocComment":" impl<T> AsRef<T> for SomeType"},{"DocComment":" where"},{"DocComment":"     T: ?Sized,"},{"DocComment":"     <SomeType as Deref>::Target: AsRef<T>,"},{"DocComment":" {"},{"DocComment":"     fn as_ref(&self) -> &T {"},{"DocComment":"         self.deref().as_ref()"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" # Reflexivity"},{"DocComment":""},{"DocComment":" Ideally, `AsRef` would be reflexive, i.e. there would be an `impl<T: ?Sized> AsRef<T> for T`"},{"DocComment":" with [`as_ref`] simply returning its argument unchanged."},{"DocComment":" Such a blanket implementation is currently *not* provided due to technical restrictions of"},{"DocComment":" Rust's type system (it would be overlapping with another existing blanket implementation for"},{"DocComment":" `&T where T: AsRef<U>` which allows `AsRef` to auto-dereference, see \"Generic Implementations\""},{"DocComment":" above)."},{"DocComment":""},{"DocComment":" [`as_ref`]: AsRef::as_ref"},{"DocComment":""},{"DocComment":" A trivial implementation of `AsRef<T> for T` must be added explicitly for a particular type `T`"},{"DocComment":" where needed or desired. Note, however, that not all types from `std` contain such an"},{"DocComment":" implementation, and those cannot be added by external code due to orphan rules."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" By using trait bounds we can accept arguments of different types as long as they can be"},{"DocComment":" converted to the specified type `T`."},{"DocComment":""},{"DocComment":" For example: By creating a generic function that takes an `AsRef<str>` we express that we"},{"DocComment":" want to accept all references that can be converted to [`&str`] as an argument."},{"DocComment":" Since both [`String`] and [`&str`] implement `AsRef<str>` we can accept both as input argument."},{"DocComment":""},{"DocComment":" [`&str`]: primitive@str"},{"DocComment":" [`Borrow`]: crate::borrow::Borrow"},{"DocComment":" [`Eq`]: crate::cmp::Eq"},{"DocComment":" [`Ord`]: crate::cmp::Ord"},{"DocComment":" [`String`]: ../../std/string/struct.String.html"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" fn is_hello<T: AsRef<str>>(s: T) {"},{"DocComment":"    assert_eq!(\"hello\", s.as_ref());"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" let s = \"hello\";"},{"DocComment":" is_hello(s);"},{"DocComment":""},{"DocComment":" let s = \"hello\".to_string();"},{"DocComment":" is_hello(s);"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"AsRef"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"},{"index":1,"name":"T"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[],"methods":[{"params":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"as_ref","attr_info":{"attributes":[{"DocComment":" Converts this type into a shared reference of the (usually inferred) input type."}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":8361}],"output":{"Deduplicated":8381}},"item":{"id":223,"generics":{"regions":[{"Var":{"Bound":[0,0]}}],"types":[{"Deduplicated":8294},{"Deduplicated":8295}],"const_generics":[],"trait_refs":[{"HashConsedValue":[8393,{"kind":"SelfId","trait_decl_ref":{"regions":[],"skip_binder":{"id":28,"generics":{"regions":[],"types":[{"Deduplicated":8294},{"Deduplicated":8295}],"const_generics":[],"trait_refs":[]}}}}]}]}}},"kind":{"TraitMethod":[28,0]}}],"vtable":{"id":{"Adt":53},"generics":{"regions":[],"types":[{"Deduplicated":8295}],"const_generics":[],"trait_refs":[]}}},{"def_id":29,"item_meta":{"name":[{"Ident":["ff",0]},{"Ident":["PrimeField",0]}],"span":{"data":{"file_id":21,"beg":{"line":195,"col":0},"end":{"line":195,"col":39}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" This represents an element of a non-binary prime field."}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":null},"generics":{"regions":[],"types":[{"index":0,"name":"Self"},{"index":1,"name":"Self_Repr"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[{"regions":[],"skip_binder":[{"Deduplicated":8295},"Static"]}],"trait_type_constraints":[]},"implied_clauses":[{"clause_id":0,"span":{"data":{"file_id":21,"beg":{"line":195,"col":22},"end":{"line":195,"col":27}},"generated_from_span":null},"origin":"WhereClauseOnTrait","trait_":{"regions":[],"skip_binder":{"id":24,"generics":{"regions":[],"types":[{"Deduplicated":8294}],"const_generics":[],"trait_refs":[]}}}},{"clause_id":1,"span":{"data":{"file_id":21,"beg":{"line":195,"col":30},"end":{"line":195,"col":39}},"generated_from_span":null},"origin":"WhereClauseOnTrait","trait_":{"regions":[],"skip_binder":{"id":7,"generics":{"regions":[],"types":[{"Deduplicated":8294},{"Deduplicated":1072}],"const_generics":[],"trait_refs":[]}}}},{"clause_id":2,"span":{"data":{"file_id":21,"beg":{"line":198,"col":15},"end":{"line":198,"col":19}},"generated_from_span":null},"origin":{"TraitItem":0},"trait_":{"regions":[],"skip_binder":{"id":3,"generics":{"regions":[],"types":[{"Deduplicated":8295}],"const_generics":[],"trait_refs":[]}}}},{"clause_id":3,"span":{"data":{"file_id":21,"beg":{"line":198,"col":22},"end":{"line":198,"col":29}},"generated_from_span":null},"origin":{"TraitItem":0},"trait_":{"regions":[],"skip_binder":{"id":23,"generics":{"regions":[],"types":[{"Deduplicated":8295}],"const_generics":[],"trait_refs":[]}}}},{"clause_id":4,"span":{"data":{"file