// Result may be within MODULUS of the correct value\n        (&Fp([r4, r5, r6, r7])).sub(&MODULUS)\n    }","attr_info":{"attributes":[{"Unknown":{"path":"allow","args":"clippy::too_many_arguments"}}],"inline":"Always","rename":null,"public":false},"is_local":true,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":1072},{"Deduplicated":1072},{"Deduplicated":1072},{"Deduplicated":1072},{"Deduplicated":1072},{"Deduplicated":1072},{"Deduplicated":1072},{"Deduplicated":1072}],"output":{"Deduplicated":1079}},"src":"TopLevel","is_global_initializer":null,"body":{"Structured":{"span":{"data":{"file_id":2,"beg":{"line":319,"col":4},"end":{"line":363,"col":5}},"generated_from_span":null},"bound_body_regions":12,"locals":{"arg_count":8,"locals":[{"index":0,"name":null,"span":{"data":{"file_id":2,"beg":{"line":328,"col":9},"end":{"line":328,"col":13}},"generated_from_span":null},"ty":{"Deduplicated":1079}},{"index":1,"name":"r0","span":{"data":{"file_id":2,"beg":{"line":320,"col":8},"end":{"line":320,"col":10}},"generated_from_span":null},"ty":{"Deduplicated":1072}},{"index":2,"name":"r1","span":{"data":{"file_id":2,"beg":{"line":321,"col":8},"end":{"line":321,"col":10}},"generated_from_span":null},"ty":{"Deduplicated":1072}},{"index":3,"name":"r2","span":{"data":{"file_id":2,"beg":{"line":322,"col":8},"end":{"line":322,"col":10}},"generated_from_span":null},"ty":{"Deduplicated":1072}},{"index":4,"name":"r3","span":{"data":{"file_id":2,"beg":{"line":323,"col":8},"end":{"line":323,"col":10}},"generated_from_span":null},"ty":{"Deduplicated":1072}},{"index":5,"name":"r4","span":{"data":{"file_id":2,"beg":{"line":324,"col":8},"end":{"line":324,"col":10}},"generated_from_span":null},"ty":{"Deduplicated":1072}},{"index":6,"name":"r5","span":{"data":{"file_id":2,"beg":{"line":325,"c