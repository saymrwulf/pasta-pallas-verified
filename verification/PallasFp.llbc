name":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":8294},{"Deduplicated":8395}],"output":{"Deduplicated":8419}},"item":{"id":290,"generics":{"regions":[{"Var":{"Bound":[0,0]}}],"types":[{"Deduplicated":8294},{"Deduplicated":8295},{"Deduplicated":8348}],"const_generics":[],"trait_refs":[{"Deduplicated":8418}]}}},"kind":{"TraitMethod":[46,5]}}],"vtable":{"id":{"Adt":64},"generics":{"regions":[],"types":[{"Deduplicated":8295},{"Deduplicated":8348}],"const_generics":[],"trait_refs":[]}}},{"def_id":47,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["convert",0]},{"Ident":["TryFrom",0]}],"span":{"data":{"file_id":9,"beg":{"line":694,"col":0},"end":{"line":694,"col":33}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Simple and safe type conversions that may fail in a controlled"},{"DocComment":" way under some circumstances. It is the reciprocal of [`TryInto`]."},{"DocComment":""},{"DocComment":" This is useful when you are doing a type conversion that may"},{"DocComment":" trivially succeed but may also need special handling."},{"DocComment":" For example, there is no way to convert an [`i64`] into an [`i32`]"},{"DocComment":" using the [`From`] trait, because an [`i64`] may contain a value"},{"DocComment":" that an [`i32`] cannot represent and so the conversion would lose data."},{"DocComment":" This might be handled by truncating the [`i64`] to an [`i32`] or by"},{"DocComment":" simply returning [`i32::MAX`], or by some other method.  The [`From`]"},{"DocComment":" trait is intended for perfect conversions, so the `TryFrom` trait"},{"DocComment":" informs the programmer when a type conversion could go bad and lets"},{"DocComment":" them decide how to handle it."},{"DocComment":""},{"DocComment":" # Generic Implementations"},{"DocComment":""},{"DocComment":" - `TryFrom<T> for U` implies [`TryInto`]`<U> for T`"},{"DocComment":" - [`try_from`] is reflexive, which means that `TryFrom<T> for T`"},{"DocComment":" is implemented and cannot fail -- the associated `Error` type for"},{"DocComment":" calling `T::try_from()` on a value of type `T` is [`Infallible`]."},{"DocComment":" When the [`!`] type is stabilized [`Infallible`] and [`!`] will be"},{"DocComment":" equivalent."},{"DocComment":""},{"DocComment":" Prefer using [`TryInto`] over [`TryFrom`] when specifying trait bounds on a generic function"},{"DocComment":" to ensure that types that only implement [`TryInto`] can be used as well."},{"DocComment":""},{"DocComment":" `TryFrom<T>` can be implemented as follows:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" struct GreaterThanZero(i32);"},{"DocComment":""},{"DocComment":" impl TryFrom<i32> for GreaterThanZero {"},{"DocComment":"     type Error = &'static str;"},{"DocComment":""},{"DocComment":"     fn try_from(value: i32) -> Result<Self, Self::Error> {"},{"DocComment":"         if value <= 0 {"},{"DocComment":"             Err(\"GreaterThanZero only accepts values greater than zero!\")"},{"DocComment":"         } else {"},{"DocComment":"             Ok(GreaterThanZero(value))"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" As described, [`i32`] implements `TryFrom<`[`i64`]`>`:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let big_number = 1_000_000_000_000i64;"},{"DocComment":" // Silently truncates `big_number`, requires detecting"},{"DocComment":" // and handling the truncation after the fact."},{"DocComment":" let smaller_number = big_number as i32;"},{"DocComment":" assert_eq!(smaller_number, -727379968);"},{"DocComment":""},{"DocComment":" // Returns an error because `big_number` is too big to"},{"DocComment":" // fit in an `i32`."},{"DocComment":" let try_smaller_number = i32::try_from(big_number);"},{"DocComment":" assert!(try_smaller_number.is_err());"},{"DocComment":""},{"DocComment":" // Returns `Ok(3)`."},{"DocComment":" let try_successful_smaller_number = i32::try_from(3);"},{"DocComment":" assert!(try_successful_smaller_number.is_ok());"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [`try_from`]: TryFrom::try_from"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"TryFrom"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"},{"index":1,"name":"T"},{"index":2,"name":"Self_Error"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[],"consts":[],"types":[null],"methods":[{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"try_from","attr_info":{"attributes":[{"DocComment":" Performs the conversion."}],"inline":null,"rename":null,"public":true},"signature":{"is_unsafe":false,"abi":"Rust","inputs":[{"Deduplicated":8295}],"output":{"Deduplicated":8425}},"item":{"id":297,"generics":{"regions":[],"types":[{"Deduplicated":8294},{"Deduplicated":8295},{"Deduplicated":8348}],"const_generics":[],"trait_refs":[{"HashConsedValue":[8426,{"kind":"SelfId","trait_decl_ref":{"regions":[],"skip_binder":{"id":47,"generics":{"regions":[],"types":[{"Deduplicated":8294},{"Deduplicated":8295},{"Deduplicated":8348}],"const_generics":[],"trait_refs":[]}}}}]}]}}},"kind":{"TraitMethod":[47,0]}}],"vtable":null},{"def_id":48,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["ops",0]},{"Ident":["index",0]},{"Ident":["IndexMut",0]}],"span":{"data":{"file_id":64,"beg":{"line":170,"col":0},"end":{"line":170,"col":57}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Used for indexing operations (`container[index]`) in mutable contexts."},{"DocComment":""},{"DocComment":" `container[index]` is actually syntactic sugar for"},{"DocComment":" `*container.index_mut(index)`, but only when used as a mutable value. If"},{"DocComment":" an immutable value is requested, the [`Index`] trait is used instead. This"},{"DocComment":" allows nice things such as `v[index] = value`."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" A very simple implementation of a `Balance` struct that has two sides, where"},{"DocComment":" each can be indexed mutably and immutably."},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ops::{Index, IndexMut};"},{"DocComment":""},{"DocComment":" #[derive(Debug)]"},{"DocComment":" enum Side {"},{"DocComment":"     Left,"},{"DocComment":"     Right,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" #[derive(Debug, PartialEq)]"},{"DocComment":" enum Weight {"},{"DocComment":"     Kilogram(f32),"},{"DocComment":"     Pound(f32),"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" struct Balance {"},{"DocComment":"     pub left: Weight,"},{"DocComment":"     pub right: Weight,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" impl Index<Side> for Balance {"},{"DocComment":"     type Output = Weight;"},{"DocComment":""},{"DocComment":"     fn index(&self, index: Side) -> &Self::Output {"},{"DocComment":"         println!(\"Accessing {index:?}-side of balance immutably\");"},{"DocComment":"         match index {"},{"DocComment":"             Side::Left => &self.left,"},{"DocComment":"             Side::Right => &self.right,"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" impl IndexMut<Side> for Balance {"},{"DocComment":"     fn index_mut(&mut self, index: Side) -> &mut Self::Output {"},{"DocComment":"         println!(\"Accessing {index:?}-side of balance mutably\");"},{"DocComment":"         match index {"},{"DocComment":"             Side::Left => &mut self.left,"},{"DocComment":"             Side::Right => &mut self.right,"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" let mut balance = Balance {"},{"DocComment":"     right: Weight::Kilogram(2.5),"},{"DocComment":"     left: Weight::Pound(1.5),"},{"DocComment":" };"},{"DocComment":""},{"DocComment":" // In this case, `balance[Side::Right]` is sugar for"},{"DocComment":" // `*balance.index(Side::Right)`, since we are only *reading*"},{"DocComment":" // `balance[Side::Right]`, not writing it."},{"DocComment":" assert_eq!(balance[Side::Right], Weight::Kilogram(2.5));"},{"DocComment":""},{"DocComment":" // However, in this case `balance[Side::Left]` is sugar for"},{"DocComment":" // `*balance.index_mut(Side::Left)`, since we are writing"},{"DocComment":" // `balance[Side::Left]`."},{"DocComment":" balance[Side::Left] = Weight::Kilogram(3.0);"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"index_mut"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"},{"index":1,"name":"Idx"},{"index":2,"name":"Self_Clause0_Output"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_clauses":[{"clause_id":0,"span":{"data":{"file_id":64,"beg":{"line":170,"col":39},"end":{"line":170,"col":57}},"generated_from_span":null},"origin":"WhereClauseOnTrait","trait_":{"regions":[],"skip_binder":{"id":45,"generics":{"regions":[],"types":[{"Deduplicated":8294},{"Deduplicated":8295},{"Deduplicated":8348}],"const_generics":[],"trait_refs":[]}}}}],"consts":[],"types":[],"methods":[{"params":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"name":"index_mut","attr_info":{"attributes":[{"DocComment":" Performs the mutable indexing (`container[index]`) operation."},{"DocComment":""},{"DocComment":" # Panics"},{"DocComment":""},{"DocComment":" May panic if the index is out of bounds."}],"inline":null,"rename":null,"